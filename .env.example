# Copy to .env and edit.
# Required
NODE_ENV=development
DOMAIN=tradingviu.localhost
JWT_SECRET=change-me-to-a-random-64-char-string-please-please-please
POSTGRES_PASSWORD=change-me
POSTGRES_USER=tradingviu
POSTGRES_DB=tradingviu
DATABASE_URL=postgresql://tv_app:change-me-app@localhost:5434/tradingviu
DATABASE_URL_ADMIN=postgresql://tradingviu:change-me@localhost:5434/tradingviu
REDIS_URL=redis://localhost:6380
MINIO_ROOT_USER=tradingviu
MINIO_ROOT_PASSWORD=change-me
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MEILI_MASTER_KEY=change-me
MEILI_HOST=http://localhost:7700
CORS_ORIGIN=http://localhost:5187
API_PORT=3101
WEB_PORT=5187

# Email (Postmark or Resend)
EMAIL_FROM=no-reply@tradingviu.localhost
POSTMARK_TOKEN=
# Outbound alert email via SMTP. Point at Mailpit for local dev (infra/docker-compose).
# Leave SMTP_HOST empty to disable email delivery (alerts still fire in-app).
SMTP_HOST=localhost
SMTP_PORT=1025

# Stripe (optional, billing disabled if blank)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTAL_RETURN_URL=http://localhost:5187/account/billing

# Data sources (BYO keys, leave blank for free tiers)
ALPACA_KEY=
ALPACA_SECRET=
POLYGON_KEY=
OANDA_KEY=
FRED_KEY=
# news provider: mock | newsapi | finnhub | benzinga
NEWS_PROVIDER=mock
NEWS_INGEST_INTERVAL_SECONDS=300
NEWS_INGEST_SYMBOLS=
NEWS_INGEST_FROM=
NEWS_INGEST_TO=
NEWS_INGEST_LIMIT=100
NEWSAPI_KEY=
FINNHUB_KEY=
BENZINGA_KEY=
FUNDAMENTALS_PROVIDER=mock
FUNDAMENTALS_INGEST_INTERVAL_SECONDS=900
FUNDAMENTALS_INGEST_SYMBOLS=AAPL,MSFT
FUNDAMENTALS_INGEST_LIMIT=50
MACRO_PROVIDER=mock
MACRO_INGEST_INTERVAL_SECONDS=900
MACRO_INGEST_COUNTRY=US
MACRO_INGEST_FROM=
MACRO_INGEST_TO=
MACRO_INGEST_LIMIT=100
CALENDAR_PROVIDER=mock
CALENDAR_INGEST_INTERVAL_SECONDS=900
CALENDAR_INGEST_SYMBOLS=AAPL,MSFT
CALENDAR_INGEST_COUNTRY=
CALENDAR_INGEST_FROM=
CALENDAR_INGEST_TO=
CALENDAR_INGEST_LIMIT=250
FMP_KEY=
COINGECKO_KEY=

# Encryption key for broker credentials (libsodium, 32 bytes hex)
CRED_ENC_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# System user for background writes (BarStore persist queue, ingest workers).
# Must match a real user in the `users` table that has global_role='super_admin',
# or just leave as 'system' — the RLS helper treats any user with is_super_admin
# context as the writer.
SYSTEM_USER_ID=system
