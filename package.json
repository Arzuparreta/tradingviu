{
  "name": "tradingviu",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted multi-tenant trading platform. TradingView, but OSS.",
  "license": "AGPL-3.0",
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "db:generate": "pnpm --filter @tv/db generate",
    "db:migrate": "pnpm --filter @tv/db migrate",
    "db:seed": "pnpm --filter @tv/db seed",
    "news:ingest": "bun run services/news-ingest/src/index.ts --once",
    "fundamentals:ingest": "bun run services/fundamentals-ingest/src/index.ts --once",
    "tvctl": "pnpm --filter @tv/cli tvctl"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
